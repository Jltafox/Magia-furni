---
import Base from '../layouts/Base.astro';
import PressBar from '../components/PressBar.astro';
import Placeholder from '../components/Placeholder.astro';
import CtaFinal from '../components/CtaFinal.astro';

// Hitos verificados — memory/user_alejandro-furnadjiev.md
const timeline = [
  { when: '7 años', what: 'La magia lo atrapa.' },
  { when: '8 años', what: 'Entra en la Escuela de Magia de Ana Tamariz.' },
  { when: '9 años', what: 'Primera actuación.' },
  { when: '11 años', what: 'Conoce a Arturo de Ascanio, que lo invita a las reuniones de su casa.' },
  { when: '12 años', what: 'Ingresa en la Sociedad Española de Ilusionismo.' },
  { when: '17 años', what: '2º premio de close-up en el festival de Valongo (Portugal).' },
  { when: '1999', what: '1er premio de Cartomagia, Congreso Nacional de España (Almería).' },
  { when: '2002', what: 'Profesor de la Gran Escuela de Magia Ana Tamariz — hasta hoy.' },
  { when: '2004', what: 'Gran Premio de Cartomagia, FLASOMA (Buenos Aires).' },
  { when: '2006', what: 'Memorial Ascanio: mejor mago del año.' },
];
---

<Base
  title="Alejandro Furnadjiev, mago | Discípulo de Ascanio"
  description="Alejandro Furnadjiev, mago profesional en Madrid: discípulo de Ascanio y Tamariz, Gran Premio de Cartomagia FLASOMA 2004 y Memorial Ascanio 2006."
>
  <section class="container intro">
    <div>
      <p class="eyebrow">Sobre Alejandro</p>
      <h1>Una vida dedicada a la <em>magia</em></h1>
      <p class="muted" style="font-size: 1.2rem; max-width: 44ch;">
        Hay magos que aprendieron trucos. Alejandro se formó con los maestros que definieron la magia
        española del siglo XX.
      </p>
    </div>
    <Placeholder ratio="4x5" label="Retrato en preparación" tilt />
  </section>

  <PressBar />

  <section class="container">
    <p class="eyebrow">La historia</p>
    <h2 style="margin-top: 0;">De la escuela de Ana Tamariz a las reuniones de <em>Ascanio</em></h2>
    <p>
      Discípulo directo de Arturo de Ascanio — el padre de la cartomagia española — y de Juan Tamariz,
      Alejandro creció dentro de la escuela que hizo de Madrid una capital mundial de la magia de cerca.
      Desde 2002 la transmite como profesor de la Gran Escuela de Magia Ana Tamariz, y la pone en juego en
      cada actuación: una magia pensada, ensayada y ejecutada con el oficio de toda una vida.
    </p>

    <ol class="timeline">
      {timeline.map((t) => (
        <li>
          <span class="when">{t.when}</span>
          <span class="what">{t.what}</span>
        </li>
      ))}
    </ol>
  </section>

  <CtaFinal text="¿Quieres esta magia en tu evento?" />
</Base>

<style>
  .intro {
    display: grid;
    gap: var(--s-6);
    align-items: center;
    grid-template-columns: 1fr;
    padding-top: var(--s-6);
  }
  @media (min-width: 721px) {
    .intro { grid-template-columns: 3fr 2fr; padding-top: var(--s-7); }
  }
  .timeline {
    list-style: none;
    margin: var(--s-5) 0 0;
    padding: 0;
    border-left: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .timeline li {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: var(--s-3);
    padding: var(--s-3) 0 var(--s-3) var(--s-4);
    position: relative;
  }
  .timeline li::before {
    content: '';
    position: absolute;
    left: -3.5px;
    top: calc(var(--s-3) + 0.55em);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .when {
    font-family: var(--font-heading);
    color: var(--accent);
    white-space: nowrap;
  }
  .what { color: var(--text); }
</style>
