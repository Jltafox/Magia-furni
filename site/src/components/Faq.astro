---
interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---

<section class="container" aria-label="Preguntas frecuentes">
  <h2>Preguntas frecuentes</h2>
  {items.map((item) => (
    <details class="faq">
      <summary>{item.q}</summary>
      <p>{item.a}</p>
    </details>
  ))}
</section>
